/* ================================================================
   STATE
================================================================ */
var studentName   = "";
var currentQ      = 0;
var answers       = [];
var timerInterval = null;
var secondsLeft   = 30 * 60;
var submitted     = false;

for (var i = 0; i < QUESTIONS.length; i++) { answers.push(-1); }

/* ================================================================
   HELPERS
================================================================ */
function getEl(id) { return document.getElementById(id); }

function showScreen(id) {
  var all = document.querySelectorAll(".screen");
  for (var i = 0; i < all.length; i++) { all[i].classList.remove("active"); }
  getEl(id).classList.add("active");
}

function pad(n) { return n < 10 ? "0" + n : "" + n; }

function formatTime(s) {
  return pad(Math.floor(s / 60)) + ":" + pad(s % 60);
}

function maxPts() {
  var t = 0;
  for (var i = 0; i < QUESTIONS.length; i++) { t += QUESTIONS[i].pts; }
  return t;
}

/* ================================================================
   START SCREEN
================================================================ */
getEl("startBtn").addEventListener("click", function () {
  var val = getEl("nameInput").value.trim();
  if (!val) {
    getEl("nameError").style.display = "block";
    getEl("nameInput").focus();
    return;
  }
  getEl("nameError").style.display = "none";
  studentName = val;
  startQuiz();
});

getEl("nameInput").addEventListener("keydown", function (e) {
  if (e.key === "Enter") { getEl("startBtn").click(); }
});

/* ================================================================
   QUIZ
================================================================ */
function startQuiz() {
  showScreen("quiz-screen");
  getEl("headerName").textContent = "👤 " + studentName;
  renderQuestion();
  startTimer();
}

function startTimer() {
  timerInterval = setInterval(function () {
    secondsLeft--;
    var tb = getEl("timerBox");
    tb.textContent = formatTime(secondsLeft);
    if (secondsLeft <= 60) {
      tb.className = "timer-box danger";
    } else if (secondsLeft <= 300) {
      tb.className = "timer-box warn";
    }
    if (secondsLeft <= 0) {
      clearInterval(timerInterval);
      doSubmit();
    }
  }, 1000);
}

function renderQuestion() {
  var q   = QUESTIONS[currentQ];
  var pct = Math.round((currentQ / QUESTIONS.length) * 100);
  getEl("progressBar").style.width = pct + "%";
  getEl("qCounter").textContent    = (currentQ + 1) + " / " + QUESTIONS.length;

  var bClass = q.band === 4 ? "band4" : (q.band === 3 ? "band3" : "band12");
  var bTag   = q.band === 4 ? "band4-tag" : (q.band === 3 ? "band3-tag" : "band12-tag");
  var bLabel = "apúntate " + q.band;
  var pLabel = q.pts + (q.pts === 1 ? " Pkt" : " Pkte");

  var html = '<div class="block-title">' + q.block + '</div>';
  html += '<div class="question-card ' + bClass + '">';
  html += '<div class="q-meta">';
  html += '<span class="q-num">Frage ' + (currentQ + 1) + '</span>';
  html += '<span class="q-band ' + bTag + '">' + bLabel + '</span>';
  html += '<span class="q-pts">' + pLabel + '</span>';
  html += '</div>';
  html += '<div class="q-text">' + q.q + '</div>';
  html += '<div class="options">';
  for (var i = 0; i < q.opts.length; i++) {
    var sel = (answers[currentQ] === i) ? " selected" : "";
    html += '<button class="opt-btn' + sel + '" data-i="' + i + '">' + q.opts[i] + '</button>';
  }
  html += '</div></div>';

  getEl("quizBody").innerHTML = html;

  /* option click */
  var btns = getEl("quizBody").querySelectorAll(".opt-btn");
  for (var j = 0; j < btns.length; j++) {
    btns[j].addEventListener("click", function () {
      answers[currentQ] = parseInt(this.getAttribute("data-i"));
      var all = getEl("quizBody").querySelectorAll(".opt-btn");
      for (var k = 0; k < all.length; k++) { all[k].classList.remove("selected"); }
      this.classList.add("selected");
    });
  }

  /* nav */
  var backBtn = getEl("backBtn");
  var nextBtn = getEl("nextBtn");
  backBtn.style.visibility = currentQ === 0 ? "hidden" : "visible";

  if (currentQ === QUESTIONS.length - 1) {
    nextBtn.textContent = "Abgeben ✓";
    nextBtn.className   = "btn-nav btn-submit";
  } else {
    nextBtn.textContent = "Weiter →";
    nextBtn.className   = "btn-nav btn-next";
  }
}

getEl("backBtn").addEventListener("click", function () {
  if (currentQ > 0) { currentQ--; renderQuestion(); }
});

getEl("nextBtn").addEventListener("click", function () {
  if (currentQ < QUESTIONS.length - 1) {
    currentQ++;
    renderQuestion();
  } else {
    if (submitted) { return; }
    var open = 0;
    for (var i = 0; i < answers.length; i++) { if (answers[i] === -1) open++; }
    if (open > 0) {
      if (!confirm(open + " Frage(n) noch unbeantwortet. Trotzdem abgeben?")) { return; }
    }
    doSubmit();
  }
});

/* ================================================================
   SUBMIT
================================================================ */
function doSubmit() {
  if (submitted) { return; }
  submitted = true;
  clearInterval(timerInterval);

  var used  = 30 * 60 - secondsLeft;
  var tStr  = pad(Math.floor(used / 60)) + " min " + pad(used % 60) + " s";

  showScreen("result-screen");
  buildResults(tStr);
}

/* ================================================================
   RESULTS
================================================================ */
function buildResults(timeStr) {
  var total = 0;
  var mp    = maxPts();

  /* per-block & per-band */
  var blocks = {};
  var BLOCK_ORDER = [
    "Zeitformen","Subjuntivo","Pronomen",
    "Nominalphrase & Syntax","Verbkonstruktionen","Semantik & Lexikogrammatik"
  ];
  for (var b = 0; b < BLOCK_ORDER.length; b++) {
    blocks[BLOCK_ORDER[b]] = { got: 0, max: 0, wrongIdx: [] };
  }

  for (var i = 0; i < QUESTIONS.length; i++) {
    var q  = QUESTIONS[i];
    var bl = blocks[q.block];
    bl.max += q.pts;
    if (answers[i] === q.correct) {
      total   += q.pts;
      bl.got  += q.pts;
    } else {
      bl.wrongIdx.push(i);
    }
  }

  var pct        = Math.round((total / mp) * 100);
  var gradeColor = pct >= 75 ? "#48bb78" : (pct >= 50 ? "#f6ad55" : "#fc8181");
  var gradeText  = pct >= 75 ? "Sehr gut – weiter so!" : (pct >= 50 ? "In Ordnung – gezielt üben!" : "Förderbedarf – systematisch wiederholen!");

  var html = "";

  /* ── header ── */
  html += '<div class="result-header">';
  html += '<h2>Ergebnis: ' + studentName + '</h2>';
  html += '<div class="big-score" style="color:' + gradeColor + '">' + pct + ' %</div>';
  html += '<div class="score-sub">' + total + ' von ' + mp + ' Punkten &nbsp;·&nbsp; ' + gradeText + '<br>Bearbeitungszeit: ' + timeStr + '</div>';
  html += '</div>';

  /* ── bar chart ── */
  html += '<div class="section-card"><h3>📊 Ergebnisse nach Bereich</h3>';
  for (var b = 0; b < BLOCK_ORDER.length; b++) {
    var bn  = BLOCK_ORDER[b];
    var bd  = blocks[bn];
    var bp  = bd.max > 0 ? Math.round((bd.got / bd.max) * 100) : 0;
    var fc  = bp >= 75 ? "fill-good" : (bp >= 50 ? "fill-ok" : "fill-poor");
    html += '<div class="bar-row">';
    html += '<div class="bar-label"><span>' + bn + '</span><span>' + bd.got + ' / ' + bd.max + ' (' + bp + ' %)</span></div>';
    html += '<div class="bar-track"><div class="bar-fill ' + fc + '" style="width:' + bp + '%"></div></div>';
    html += '</div>';
  }
  html += '</div>';

  /* ── Förderempfehlungen ── */
  var foerder = [];
  for (var b = 0; b < BLOCK_ORDER.length; b++) {
    var bn = BLOCK_ORDER[b];
    var bd = blocks[bn];
    var bp = bd.max > 0 ? Math.round((bd.got / bd.max) * 100) : 0;
    if (bp === 100) { continue; }
    var lvl, cls;
    if (bp < 50)       { lvl = "hoch";    cls = "foerder-hoch"; }
    else if (bp < 75)  { lvl = "mittel";  cls = "foerder-mittel"; }
    else               { lvl = "niedrig"; cls = "foerder-niedrig"; }

    /* collect bands of wrong answers */
    var bandSet = {};
    for (var wi = 0; wi < bd.wrongIdx.length; wi++) {
      bandSet["apúntate " + QUESTIONS[bd.wrongIdx[wi]].band] = true;
    }
    var bandStr = Object.keys(bandSet).join(", ");

    foerder.push({ lvl: lvl, cls: cls, name: bn, pct: bp, band: bandStr, desc: getFoerderDesc(bn, bp) });
  }

  /* sort: hoch → mittel → niedrig */
  foerder.sort(function (a, b) {
    var o = { hoch: 0, mittel: 1, niedrig: 2 };
    return o[a.lvl] - o[b.lvl];
  });

  html += '<div class="section-card"><h3>🎯 Individuelle Förderempfehlungen</h3>';
  if (foerder.length === 0) {
    html += '<p style="color:#276749;font-weight:600">🏆 Alle Bereiche ≥ 100 % – hervorragende Leistung!</p>';
  }
  for (var f = 0; f < foerder.length; f++) {
    var fi   = foerder[f];
    var icon = fi.lvl === "hoch" ? "🔴" : (fi.lvl === "mittel" ? "🟡" : "🟢");
    html += '<div class="foerder-item ' + fi.cls + '">';
    html += '<div class="fi-band">' + fi.band + '</div>';
    html += '<div class="fi-title">' + icon + ' ' + fi.name + ' &nbsp;–&nbsp; Priorität: ' + fi.lvl + ' (' + fi.pct + ' %)</div>';
    html += '<div class="fi-desc">' + fi.desc + '</div>';
    html += '</div>';
  }
  html += '</div>';

  /* ── Detailed answers ── */
  html += '<div class="section-card"><h3>📝 Alle Fragen im Detail</h3></div>';
  for (var i = 0; i < QUESTIONS.length; i++) {
    var q    = QUESTIONS[i];
    var ok   = answers[i] === q.correct;
    var icon = ok ? "✅" : "❌";
    var given = answers[i] >= 0 ? q.opts[answers[i]] : "(keine Antwort)";

    html += '<div class="ans-card ' + (ok ? "correct" : "wrong") + '">';
    html += '<div class="ans-top">';
    html += '<span class="ans-icon">' + icon + '</span>';
    html += '<span class="ans-q">Frage ' + (i + 1) + ': ' + q.q + '</span>';
    html += '</div>';
    html += '<div class="ans-detail">';
    if (!ok) {
