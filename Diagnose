<script>
/* ================================================================
   FRAGEN-DATEN
   band: 4 = 3 Punkte | band: 3 = 2 Punkte | band: 1/2 = 1 Punkt
================================================================ */
var QUESTIONS = [

  /* ── BLOCK 1: ZEITFORMEN ─────────────────────────────────── */
  {
    block:"Zeitformen", band:4, pts:3,
    q:"Wähle die korrekte Form des <em>pretérito pluscuamperfecto</em>: Cuando llegamos, ella ya _____ (irse).",
    opts:["se había ido","se fue","se ha ido","se iba"],
    correct:0,
    expl:"Das pretérito pluscuamperfecto (había + Partizip) beschreibt eine Handlung, die vor einem vergangenen Zeitpunkt abgeschlossen war. Bei reflexiven Verben steht das Reflexivpronomen vor había."
  },
  {
    block:"Zeitformen", band:4, pts:3,
    q:"Ergänze mit dem <em>futuro simple</em>: Mañana _____ (nosotros / tener) el examen.",
    opts:["tendremos","tenemos","vamos a tener","tuvimos"],
    correct:0,
    expl:"Tener ist im futuro simple unregelmäßig: Stamm tendr- + Endungen (-é/-ás/-á/-emos/-éis/-án). Futuro inmediato (ir a + Inf.) und Präsens sind möglich, aber hier ist das futuro simple gefragt."
  },
  {
    block:"Zeitformen", band:4, pts:3,
    q:"Welche Aussage über den <em>condicional simple</em> ist korrekt?",
    opts:[
      "Er drückt Höflichkeit oder Hypothesen aus (z. B. ¿Podrías ayudarme?)",
      "Er wird mit ir a + Infinitivo gebildet",
      "Er drückt eine abgeschlossene Vergangenheit aus",
      "Er hat dieselben Endungen wie der subjuntivo presente"
    ],
    correct:0,
    expl:"Der condicional simple (hablaría, tendría …) drückt Höflichkeit, Wunsch oder hypothetische Aussagen aus. Bildung: Infinitiv + -ía/-ías/-ía/-íamos/-íais/-ían."
  },
  {
    block:"Zeitformen", band:4, pts:3,
    q:"<em>Pretérito perfecto vs. indefinido</em> – Welcher Satz ist im europäischen Spanisch korrekt?",
    opts:[
      "Este año he viajado a muchos países.",
      "Este año viajé a muchos países.",
      "Este año viajaba a muchos países.",
      "Este año había viajado a muchos países."
    ],
    correct:0,
    expl:"Im europäischen Spanisch steht das pretérito perfecto mit Zeitmarkern, die die Gegenwart einschließen (este año, hoy, ya, todavía). Das indefinido wäre eher lateinamerikanisch oder bei klar abgeschlossenen Zeiträumen korrekt."
  },
  {
    block:"Zeitformen", band:4, pts:3,
    q:"Alle drei Vergangenheitszeiten – wähle die richtige Kombination: Cuando _____ (llegar, yo), mis amigos ya _____ (comer) y la película _____ (empezar).",
    opts:[
      "llegué / habían comido / había empezado",
      "llegaba / comieron / empezó",
      "llegué / comían / había empezado",
      "había llegado / habían comido / empezó"
    ],
    correct:0,
    expl:"Llegué (indefinido) = die eintretende Handlung. Habían comido & había empezado (pluscuamperfecto) = beide vor der Ankunft bereits abgeschlossene Handlungen."
  },
  {
    block:"Zeitformen", band:4, pts:3,
    q:"Was drückt folgender Satz aus? <em>Cuando llegues, te llamo.</em>",
    opts:[
      "Eine zukünftige Bedingung – subjuntivo nach cuando für Zukünftiges",
      "Eine gegenwärtige Gewohnheit",
      "Eine vergangene Handlung",
      "Eine Möglichkeit in der Vergangenheit"
    ],
    correct:0,
    expl:"Nach cuando steht der subjuntivo presente, wenn die Handlung in der Zukunft liegt. Der Hauptsatz steht im Präsens oder futuro simple."
  },
  {
    block:"Zeitformen", band:3, pts:2,
    q:"Bilde das <em>pretérito imperfecto</em>: De niño, mi padre siempre _____ (escuchar) música clásica.",
    opts:["escuchaba","escuchó","ha escuchado","escuche"],
    correct:0,
    expl:"Das pretérito imperfecto (-aba/-abas/-aba …) beschreibt vergangene Gewohnheiten oder Zustände. 'De niño' und 'siempre' sind typische Signalwörter."
  },
  {
    block:"Zeitformen", band:3, pts:2,
    q:"<em>Indefinido oder imperfecto?</em> Ayer _____ (yo/ver) una película mientras _____ (llover).",
    opts:["vi / llovía","veía / llovió","vi / llovió","veía / llovía"],
    correct:0,
    expl:"Vi (indefinido) = einmalige abgeschlossene Handlung. Llovía (imperfecto) = Hintergrundzustand, der die Haupthandlung begleitet (Signalwort: mientras)."
  },
  {
    block:"Zeitformen", band:2, pts:1,
    q:"Forme das <em>pretérito indefinido</em>: El año pasado, nosotros _____ (ir) a la playa.",
    opts:["fuimos","íbamos","hemos ido","vamos"],
    correct:0,
    expl:"Ir ist im pretérito indefinido unregelmäßig und hat dieselben Formen wie ser: fui, fuiste, fue, fuimos, fuisteis, fueron. 'El año pasado' → indefinido."
  },
  {
    block:"Zeitformen", band:2, pts:1,
    q:"Was bedeutet <em>estar + gerundio</em> in: <em>Ahora mismo estoy estudiando.</em>?",
    opts:[
      "Ich lerne gerade in diesem Moment (Verlaufsform)",
      "Ich werde gleich lernen",
      "Ich habe gelernt",
      "Ich lerne normalerweise"
    ],
    correct:0,
    expl:"Estar + gerundio bildet die Verlaufsform und drückt aus, dass eine Handlung genau jetzt stattfindet (ahora mismo = gerade jetzt)."
  },

  /* ── BLOCK 2: SUBJUNTIVO ─────────────────────────────────── */
  {
    block:"Subjuntivo", band:4, pts:3,
    q:"Subjuntivo im Relativsatz: Busco un piso que _____ (estar) cerca del metro.",
    opts:["esté","está","estará","estaba"],
    correct:0,
    expl:"Nach einem indefiniten oder nicht-existenten Bezugsnomen steht der subjuntivo im Relativsatz. Die Wohnung existiert noch nicht/ist unbekannt → esté (subjuntivo)."
  },
  {
    block:"Subjuntivo", band:4, pts:3,
    q:"Subjuntivo nach <em>aunque</em>: Welche Aussage ist korrekt?",
    opts:[
      "Aunque + subjuntivo = auch wenn (hypothetisch); aunque + indicativo = obwohl (bekannte Tatsache)",
      "Aunque verlangt immer den subjuntivo",
      "Aunque verlangt immer den indicativo",
      "Aunque wird nur mit dem imperfecto verwendet"
    ],
    correct:0,
    expl:"Aunque + subjuntivo = auch wenn (es unklar/hypothetisch ist). Aunque + indicativo = obwohl (bekannte Tatsache). Beide Formen sind korrekt – mit unterschiedlicher Bedeutung."
  },
  {
    block:"Subjuntivo", band:4, pts:3,
    q:"Infinitivo oder subjuntivo? Wähle: Quiero _____ este libro. / Quiero que tú _____ este libro.",
    opts:[
      "leer / leas",
      "leer / lees",
      "lea / leas",
      "leer / lea"
    ],
    correct:0,
    expl:"Gleiches Subjekt → Infinitivo (Quiero leer). Verschiedene Subjekte → subjuntivo nach querer que (Quiero que tú leas)."
  },
  {
    block:"Subjuntivo", band:3, pts:2,
    q:"Wähle den korrekten subjuntivo: No creo que _____ (ser) verdad.",
    opts:["sea","es","fue","sería"],
    correct:0,
    expl:"No creo que / dudo que lösen den subjuntivo aus (Zweifel). Ser → subjuntivo presente → sea."
  },
  {
    block:"Subjuntivo", band:3, pts:2,
    q:"Welcher Satz verwendet den subjuntivo korrekt?",
    opts:[
      "Espero que venga pronto.",
      "Espero que viene pronto.",
      "Espero de que venga pronto.",
      "Espero venir pronto. (verschiedene Subjekte)"
    ],
    correct:0,
    expl:"Espero que + subjuntivo (verschiedene Subjekte). Ohne que steht der Infinitivo bei gleichem Subjekt. 'Espero de que' ist grammatisch falsch."
  },
  {
    block:"Subjuntivo", band:3, pts:2,
    q:"Es importante que todos _____ (hacer) su tarea.",
    opts:["hagan","hacen","harán","hicieron"],
    correct:0,
    expl:"Nach es importante/necesario/fundamental que folgt der subjuntivo. Hacer ist unregelmäßig: haga, hagas, haga, hagamos, hagáis, hagan."
  },
  {
    block:"Subjuntivo", band:3, pts:2,
    q:"Wähle den richtigen Modus: Ojalá _____ (tener, nosotros) más tiempo.",
    opts:["tengamos","tenemos","tendremos","tuviéramos"],
    correct:0,
    expl:"Ojalá löst immer den subjuntivo aus. Presente de subjuntivo von tener (nosotros): tengamos. (Das imperfecto de subjuntivo tuviéramos ist in apúntate 1–4 nicht eingeführt.)"
  },

  /* ── BLOCK 3: PRONOMEN ───────────────────────────────────── */
  {
    block:"Pronomen", band:4, pts:3,
    q:"Doppelpronomen beim bejahten Imperativ (tú, Singular): 'Gib es mir!' → <em>¡_____ !</em>",
    opts:["¡Dámelo!","¡Me lo da!","¡Dámele!","¡Lo dame!"],
    correct:0,
    expl:"Beim bejahten Imperativ werden Pronomen angehängt: dame + lo → ¡Dámelo! Reihenfolge: erst indirektes (me), dann direktes Objektpronomen (lo). Akzent wird gesetzt."
  },
  {
    block:"Pronomen", band:4, pts:3,
    q:"Possessivpronomen: 'Das Buch ist meins.' → <em>El libro es _____.</em>",
    opts:["mío","mi","mía","mí"],
    correct:0,
    expl:"Betonte Possessivpronomen: mío/mía/míos/mías (meiner/meine/meins …). El libro (maskulin) → mío."
  },
  {
    block:"Pronomen", band:4, pts:3,
    q:"Pronomen beim gerundio: 'Ich lese es gerade.' → Wähle die korrekte Form.",
    opts:[
      "Estoy leyéndolo. (Pronomen angehängt an gerundio)",
      "Lo estoy leyendo. (Pronomen vorgezogen)",
      "Beide Varianten sind korrekt.",
      "Estoy lo leyendo."
    ],
    correct:2,
    expl:"Bei estar + gerundio kann das Pronomen entweder angehängt werden (leyéndolo, mit Akzent) oder vor estar stehen (lo estoy leyendo). Beide Varianten sind grammatisch korrekt."
  },
  {
    block:"Pronomen", band:3, pts:2,
    q:"Doppeltes Objektpronomen: ¿Me prestas el bolígrafo? – Sí, _____ presto.",
    opts:["te lo","se lo","me lo","lo te"],
    correct:0,
    expl:"Direktes Obj.: el bolígrafo → lo; indirektes Obj.: a ti → te. Reihenfolge: indir. vor dir. → te lo. (se lo nur bei le/les + lo/la in der 3. Person.)"
  },
